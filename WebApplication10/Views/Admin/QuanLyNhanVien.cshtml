@model IEnumerable<WebApplication10.Models.NhanVien>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Nhân Sự - Lumina Admin</title>
    <!-- Thư viện hỗ trợ -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- File CSS chính của bạn -->
    <link rel="stylesheet" href="~/css/lumina-style.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar (Sử dụng class .sidebar trong CSS của bạn) -->
        @await Html.PartialAsync("_SidebarAdmin")

        <!-- Nội dung chính (Sử dụng class .main-content) -->
        <!-- Nội dung chính -->
        <div class="main-content">
    
            <!-- Tiêu đề: Đã thêm class text-gold để màu giống nút Thêm mới -->
            <h2 class="page-title text-uppercase text-gold" style="font-weight: 800;">
                Quản lý nhân viên
            </h2>

            <div class="d-flex justify-content-between align-items-end mb-4">
                <!-- Tìm kiếm -->
                <div style="width: 400px;">
                    <label class="fw-bold mb-2" style="color: var(--dark-blue)">Tìm kiếm nhân viên:</label>
                    <div class="input-group">
                        <input type="text" class="form-control" placeholder="Nhập tên hoặc mã..."
                               style="border: 1px solid var(--primary-gold); height: 45px; border-radius: 8px 0 0 8px;">
                        <button class="btn" type="button"
                                style="background: var(--dark-blue); color: white; height: 45px; padding: 0 25px; border-radius: 0 8px 8px 0;">
                            <i class="fas fa-search me-2"></i>Tìm kiếm
                        </button>
                    </div>
                </div>

                <!-- Nút Thêm mới (Màu vàng chủ đạo) -->
                <button class="btn-save" style="height: 45px; padding: 0 30px; font-size: 0.9rem; background-color: var(--primary-gold);">
                    <i class="fas fa-plus-circle me-2"></i>Thêm mới nhân viên
                </button>
            </div>

            <!-- Bảng danh sách -->
            <div class="table-container p-0 shadow-lg">
                <table class="table table-hover mb-0">
                    <thead style="background: var(--dark-blue); color: var(--primary-gold);">
                        <tr>
                            <th class="text-center p-3">MÃ NV</th>
                            <th class="p-3">HỌ TÊN</th>
                            <th class="text-center p-3">CHỨC VỤ</th>
                            <th class="text-center p-3">THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr style="vertical-align: middle;">
                                <td class="text-center fw-bold text-muted p-3">#@item.MaNV</td>
                                <td class="fw-bold p-3">@item.HoTen</td>
                                <td class="text-center p-3">
                                    <span class="badge @(item.ChucVu?.TenChucVu == "Admin" ? "bg-primary" : "bg-secondary") px-3 py-2" style="border-radius: 6px;">
                                        @item.ChucVu?.TenChucVu
                                    </span>
                                </td>
                                <td class="text-center p-3">
                                    <button class="btn-gold-outline" style="width: auto; padding: 6px 18px; font-size: 0.85rem; margin-right: 10px; border-radius: 50px;">
                                        <i class="fas fa-calendar-alt me-1"></i> Sửa ca làm
                                    </button>
                            
                                    <button class="btn btn-outline-danger btn-sm" style="border-radius: 50px; width: 35px; height: 35px;">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
