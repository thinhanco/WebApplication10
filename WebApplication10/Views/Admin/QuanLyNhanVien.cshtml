@model IEnumerable<WebApplication10.Models.NhanVien>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Nhân Sự - Lumina Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/lumina-style.css" asp-append-version="true" />

</head>
<body>
    <div class="d-flex">
        @await Html.PartialAsync("_SidebarAdmin")

        <div class="main-content">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 style="font-family: 'Poppins', sans-serif; color: #d4af37; font-weight: 700;">QUẢN LÝ NHÂN VIÊN</h2>
                <button class="btn btn-dark" style="background: #d4af37; border:none;"><i class="fas fa-user-plus me-2"></i>Thêm nhân viên</button>
            </div>

            <div class="table-container p-0">
                <table class="table table-hover mb-0">
                    <thead style="background: #1a252f; color: #d4af37;">
                        <tr>
                            <th class="p-3">MÃ NV</th>
                            <th class="p-3">HỌ TÊN</th>
                            <th class="p-3">CHỨC VỤ</th>
                            <th class="p-3">THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="p-3">#@item.MaNV</td>
                                <td class="p-3 fw-bold">@item.HoTen</td>
                                <td class="p-3">
                                    <span class="badge @(item.ChucVu?.TenChucVu == "Admin" ? "bg-primary" : "bg-secondary")">
                                        @item.ChucVu?.TenChucVu
                                    </span>
                                </td>
                                <td class="p-3">
                                    <button class="btn btn-sm btn-outline-dark me-2"><i class="fas fa-edit"></i> Sửa</button>
                                    <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i> Xóa</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>