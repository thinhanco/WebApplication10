@model IEnumerable<WebApplication10.Models.TaiKhoans>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Quản Lý Tài Khoản - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/lumina-style.css" asp-append-version="true" />

</head>
<body>
    <div class="d-flex">
        @await Html.PartialAsync("_SidebarAdmin")
        <div class="main-content">
            <h2 style="font-family: 'Poppins', sans-serif; color: #d4af37; font-weight: 700; margin-bottom: 30px;">
                QUẢN LÝ TÀI KHOẢN HỆ THỐNG
            </h2>

            <div class="table-container p-0">
                <table class="table table-hover mb-0">
                    <thead style="background: #1a252f; color: #d4af37;">
                        <tr>
                            <th class="p-3">TÊN ĐĂNG NHẬP</th>
                            <th class="p-3">CHỦ TÀI KHOẢN</th>
                            <th class="p-3">TRẠNG THÁI</th>
                            <th class="p-3">HÀNH ĐỘNG</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var acc in Model)
                        {
                            <tr>
                                <td class="p-3 fw-bold">@acc.TenDangNhap</td>
                                <td class="p-3">@acc.NhanVien.HoTen</td>
                                <td class="p-3">
                                    @if (acc.IsLocked == true)
                                    {
                                        <span class="badge bg-danger">BỊ KHÓA</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">HOẠT ĐỘNG</span>
                                    }
                                </td>
                                <td class="p-3">
                                    <form action="/Admin/ToggleLock" method="post">
                                        <input type="hidden" name="username" value="@acc.TenDangNhap" />
                                        @if (acc.IsLocked == true)
                                        {
                                            <button class="btn btn-sm btn-outline-success">Mở khóa</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-danger">Khóa lại</button>
                                        }
                                        <button type="button" class="btn btn-sm btn-outline-dark"><i class="fas fa-edit"></i> Sửa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>