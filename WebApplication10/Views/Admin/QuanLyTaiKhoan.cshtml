@model IEnumerable<WebApplication10.Models.Account>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Quản Lý Tài Khoản - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/lumina-style.css" asp-append-version="true" />

</head>
<body>
    <div class="d-flex">
        @await Html.PartialAsync("_SidebarAdmin")

        <div class="main-content">
            <h2 style="font-family: 'Poppins', sans-serif; color: #d4af37; font-weight: 700; margin-bottom: 30px;">
                QUẢN LÝ TÀI KHOẢN HỆ THỐNG
            </h2>
            <!-- THÊM FORM TÌM KIẾM TẠI ĐÂY -->
            <!-- FORM TÌM KIẾM ĐÃ SỬA -->
            <!-- FORM TÌM KIẾM CHUẨN -->
            <div class="mb-4">
                <form asp-action="QuanLyTaiKhoan" asp-controller="Admin" method="get" class="row g-2">
                    <div class="col-md-4">
                        <input type="text" name="searchString" class="form-control"
                               placeholder="Tìm theo username hoặc tên nhân viên..."
                               value="@ViewBag.CurrentFilter" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100" style="background-color: #d4af37; border: none;">
                            <i class="fas fa-search"></i> Tìm kiếm
                        </button>
                    </div>
                    <div class="col-md-2">
                        <!-- Sửa href thành asp-action để nó tự tìm đúng đường dẫn -->
                        <a asp-action="QuanLyTaiKhoan" asp-controller="Admin" class="btn btn-secondary w-100">Reset</a>
                    </div>
                </form>
            </div>
            <div class="table-container p-0">
                <table class="table table-hover mb-0">
                    <thead style="background: #1a252f; color: #d4af37;">
                        <tr>
                            <th class="p-3">TÊN ĐĂNG NHẬP</th>
                            <th class="p-3">CHỦ TÀI KHOẢN</th>
                            <th class="p-3">TRẠNG THÁI</th>
                            <th class="p-3">HÀNH ĐỘNG</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var acc in Model)
                        {
                            <tr>
                                <td class="p-3 fw-bold">@acc.Username</td>
                                <td class="p-3">@(acc.NhanVien?.HoTen ?? "Khách hàng")</td>
                                <td class="p-3">
                                </td>
                                <td class="p-3">
                                    <form action="/Admin/ToggleLock" method="post">
                                        <input type="hidden" name="username" value="@acc.Username" />
                                        
                                        <button type="button" class="btn btn-sm btn-outline-dark"><i class="fas fa-edit"></i> Sửa</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
