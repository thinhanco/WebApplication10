@model IEnumerable<WebApplication10.Models.ViewModels.DayScheduleViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Lịch Làm Trong Tuần - Lumina Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/lumina-style.css" asp-append-version="true" />
   
</head>
<body>
    <div class="d-flex">
        @await Html.PartialAsync("_SidebarNhanVien")

        <div class="main-content w-100 p-4">
            <div style="height: 20px;"></div>

            <h2 style="font-family: 'Playfair Display', serif; color: #d4af37;">Đăng Ký Lịch Làm Tuần Này</h2>
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            <form asp-action="DangKyCa" asp-controller="NhanVien" method="post">
                <div class="schedule-table table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <!-- SỬA LỖI TẠI ĐÂY: Dùng Model thay vì ViewBag -->
                                @foreach (var day in Model)
                                {
                                    <th>
                                        <span class="day-label">@day.DayOfWeekName</span>
                                        <span class="date-label">@day.Date.ToString("dd/MM")</span>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                @foreach (var day in Model)
                                {
                                    <td>
                                        @foreach (var shift in day.Shifts)
                                        {
                                            <label class="w-100 @(shift.IsFull && !shift.IsRegistered ? "shift-full" : "")">
                                                <input type="checkbox" name="selectedShifts"
                                                       value="@shift.MaCa|@shift.NgayLamStr"
                                                       class="shift-checkbox"
                                                @(shift.IsRegistered ? "checked" : "")
                                                @(shift.IsRegistered || shift.IsFull ? "disabled" : "")>
                                    
                                                <div class="shift-card">
                                                    <span class="shift-name d-block fw-bold">@shift.TenCa</span>
                                                    <span class="shift-time d-block small">@shift.GioLam</span>
                                        
                                                    <div class="shift-status">
                                                        @if (shift.IsRegistered)
                                                        {
                                                            <span class="text-success fw-bold"><i class="fas fa-check-circle"></i> Của bạn</span>
                                                        }
                                                        else if (shift.IsFull)
                                                        {
                                                            <span class="text-danger fw-bold"><i class="fas fa-lock"></i> Đã đầy (@shift.CurrentCount/@shift.MaxCount)</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted"><i class="fas fa-user"></i> Trống (@shift.CurrentCount/@shift.MaxCount)</span>
                                                        }
                                                    </div>
                                                </div>
                                            </label>
                                        }
                                    </td>
                                }
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary px-5 py-2" style="background-color: #d4af37; border-color: #d4af37;">XÁC NHẬN ĐĂNG KÝ</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
