@model IEnumerable<WebApplication10.Models.CaLam>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lịch Làm Trong Tuần - Lumina Hotel</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Lumina CSS chính -->
    <link rel="stylesheet" href="~/css/lumina-style.css" asp-append-version="true" />
   

</head>
<body>

    <div class="d-flex">
        <!-- Sidebar -->
        @await Html.PartialAsync("_SidebarNhanVien")

        <!-- Main Content -->
        <div class="main-content">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="page-title">Đăng Ký Lịch Làm Tuần Này</h2>
                <span class="badge bg-dark p-2">
                    Tuần: @ViewBag.WeekDays[0].ToString("dd/MM") - @ViewBag.WeekDays[6].ToString("dd/MM/yyyy")
                </span>
            </div>

            <form asp-controller="NhanVien" asp-action="DangKyCa" method="post">
                <div class="schedule-table table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                @foreach (DateTime day in ViewBag.WeekDays)
                                {
                                    <th>
                                        <span class="day-label">@day.ToString("dddd")</span>
                                        <span class="date-label">@day.ToString("dd/MM")</span>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                @foreach (DateTime day in ViewBag.WeekDays)
                                {
                                    <td>
                                        @foreach (var shift in Model)
                                        {
                                            <label>
                                                <input type="checkbox"
                                                       name="selectedShifts"
                                                       value="@(shift.MaCa)_@(day.ToString("yyyy-MM-dd"))"
                                                       class="shift-checkbox">
                                                <div class="shift-card">
                                                    <span class="shift-name">@shift.TenCa</span>
                                                    <span class="shift-time">
                                                        @shift.GioBatDau.ToString(@"hh\:mm") - @shift.GioKetThuc.ToString(@"hh\:mm")
                                                    </span>
                                                </div>
                                            </label>
                                        }
                                    </td>
                                }
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="text-center mt-5">
                    <p class="text-muted small mb-3">
                        <i class="fas fa-info-circle me-1"></i>
                        Nhấn vào các ca bạn muốn làm, sau đó nhấn nút xác nhận bên dưới.
                    </p>
                    <button type="submit" class="btn-save">XÁC NHẬN ĐĂNG KÝ LỊCH</button>
                </div>
            </form>
        </div>
    </div>

</body>
</html>