@model IEnumerable<WebApplication10.Models.CaLam>
@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Lịch Làm Trong Tuần - Lumina Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @await Html.PartialAsync("_SidebarStyles")
    <style>
        .schedule-table { border-radius: 15px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); background: white; }
        .schedule-table thead { background: var(--dark-blue); color: var(--primary-gold); text-align: center; }
        .schedule-table th { padding: 20px 10px; font-family: 'Playfair Display', serif; font-size: 0.9rem; border: none; }
        .schedule-table td { border: 1px solid #f0f0f0; vertical-align: top; padding: 15px; width: 14%; }
        
        .day-label { display: block; font-weight: bold; color: #333; margin-bottom: 5px; }
        .date-label { display: block; font-size: 0.8rem; color: #888; margin-bottom: 15px; }

        /* Style cho nút chọn ca */
        .shift-checkbox { display: none; }
        .shift-card {
            display: block; padding: 10px; border: 1px solid #eee; border-radius: 8px;
            margin-bottom: 10px; cursor: pointer; transition: 0.3s; text-align: center;
        }
        .shift-card:hover { border-color: var(--primary-gold); background: rgba(212, 175, 55, 0.05); }
        .shift-checkbox:checked + .shift-card {
            background: var(--primary-gold); color: white; border-color: var(--primary-gold);
            box-shadow: 0 4px 10px rgba(212, 175, 55, 0.3);
        }
        .shift-name { display: block; font-weight: 600; font-size: 0.85rem; }
        .shift-time { display: block; font-size: 0.7rem; opacity: 0.8; }
        
        .btn-save {
            background: var(--primary-gold); color: white; border: none;
            padding: 15px 40px; border-radius: 50px; font-weight: bold;
            box-shadow: 0 5px 20px rgba(212, 175, 55, 0.4); transition: 0.3s;
        }
        .btn-save:hover { background: #b5952f; transform: scale(1.05); color: white; }
    </style>
</head>
<body>
    <div class="d-flex">
        @await Html.PartialAsync("_SidebarNhanVien")

        <div class="main-content">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 style="font-family: 'Playfair Display', serif; color: #d4af37;">Đăng Ký Lịch Làm Tuần Này</h2>
                <span class="badge bg-dark p-2">Tuần: @ViewBag.WeekDays[0].ToString("dd/MM") - @ViewBag.WeekDays[6].ToString("dd/MM/yyyy")</span>
            </div>

            <form action="/NhanVien/SaveWeeklySchedule" method="post">
                <div class="schedule-table table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                @foreach (DateTime day in ViewBag.WeekDays)
                                {
                                    <th>
                                        <span class="day-label">@day.ToString("dddd")</span>
                                        <span class="date-label">@day.ToString("dd/MM")</span>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                @foreach (DateTime day in ViewBag.WeekDays)
                                {
                                    <td>
                                        @foreach (var shift in Model)
                                        {
                                            <label>
                                                <!-- Value là: MãCa_Ngày (Ví dụ: 1_2026-04-01) -->
                                                <input type="checkbox" name="selectedShifts" 
                                                       value="@(shift.MaCa)_@(day.ToString("yyyy-MM-dd"))" 
                                                       class="shift-checkbox">
                                                <div class="shift-card">
                                                    <span class="shift-name">@shift.TenCa</span>
                                                    <span class="shift-time">@shift.GioBatDau.ToString(@"hh\:mm") - @shift.GioKetThuc.ToString(@"hh\:mm")</span>
                                                </div>
                                            </label>
                                        }
                                    </td>
                                }
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="text-center mt-5">
                    <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i> Nhấn vào các ca bạn muốn làm, sau đó nhấn nút xác nhận bên dưới.</p>
                    <button type="submit" class="btn btn-save">XÁC NHẬN ĐĂNG KÝ LỊCH</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>