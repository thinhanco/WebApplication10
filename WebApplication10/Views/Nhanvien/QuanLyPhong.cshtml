@using WebApplication10.Models.ViewModels
@model IEnumerable<QuanLyPhongViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Phòng - Lumina Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/lumina-style.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex">
        @await Html.PartialAsync("_SidebarNhanVien")

        <div class="main-content">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 style="font-family: 'Playfair Display', serif; color: #d4af37;">Quản lý phòng</h2>
                
                <form asp-action="QuanLyPhong" method="get" class="d-flex search-container">
                    <div class="input-group shadow-sm">
                        <input type="text" name="searchString" value="@ViewBag.CurrentSearch"
                               class="form-control border-0" placeholder="Tìm số phòng...">
                        <button class="btn btn-gold" type="submit"><i class="fas fa-search"></i></button>
                    </div>
                </form>
            </div>

            <div class="table-container">
                <table class="table custom-table mb-0">
                    <thead>
                        <tr>
                            <th>SỐ PHÒNG</th>
                            <th>LOẠI PHÒNG</th>
                            <th>TRẠNG THÁI</th>
                            <th>THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="4" class="text-center py-5 text-muted">Không tìm thấy phòng phù hợp.</td></tr>
                        }
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@p.SoPhong</td>
                                <td>@p.LoaiPhong</td>
                                <td>
                                    <span class="badge-status @p.BadgeClass">@p.TrangThaiDisplay</span>
                                </td>
                                <td>
                                    <form action="/NhanVien/CapNhatTrangThaiPhong" method="post" class="d-flex align-items-center gap-2">
                                        <input type="hidden" name="soPhong" value="@p.SoPhong" />
                                        
                                        <select name="trangThaiMoi" class="form-select form-select-sm border-0 bg-light" style="width:130px;">
                                            <! -- Ở đây logic Selected cũng rất đơn giản -->
                                            <option value="Trống" selected="@(p.TrangThaiDisplay == "Trống")">Trống</option>
                                            <option value="Đang ở" selected="@(p.TrangThaiDisplay == "Đang ở")">Đang ở</option>
                                            <option value="Đang dọn dẹp" selected="@(p.TrangThaiDisplay == "Đang dọn dẹp")">Đang dọn dẹp</option>
                                            <option value="Bảo trì" selected="@(p.TrangThaiDisplay == "Bảo trì")">Bảo trì</option>
                                        </select>
                                        
                                        <button type="submit" class="btn btn-sm text-white fw-bold" style="background:#d4af37; padding: 4px 15px;">Lưu</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
