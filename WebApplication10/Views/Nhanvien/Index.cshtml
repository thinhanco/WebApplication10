@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Tổng Quan Nhân Viên - Lumina Hotel</title>
    <!-- Bootstrap & Google Fonts -->
    <link rel="stylesheet" href="~/css/lumina-style.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- GỌI CSS DÙNG CHUNG (Để Sidebar và Font được đồng bộ) -->

    
</head>
<body>
    <div class="d-flex">
        <!-- SIDEBAR -->
        @await Html.PartialAsync("_SidebarNhanVien")

        <!-- MAIN CONTENT -->
        <div class="main-content">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <h2 class="page-title">Tác Vụ Nhân Viên</h2>
                
                <div class="user-welcome">
                    <i class="far fa-user-circle text-gold me-2"></i>
                    Chào, <strong>@ViewBag.HoTen</strong>
                </div>
            </div>

            <div class="row g-4">
                <!-- Card 1 -->
                <div class="col-md-4">
                    <div class="uc-card">
                        <i class="fas fa-calendar-alt fa-2x text-gold"></i>
                        <h3>Đặt Ca Làm</h3>
                        <p>Xem danh sách ca làm việc theo tuần, đăng ký ca làm mới và tìm kiếm lịch trình phù hợp.</p>
                        <a href="/NhanVien/DatCaLam" class="btn-gold-action">TRUY CẬP</a>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="col-md-4">
                    <div class="uc-card">
                        <i class="fas fa-bed fa-2x text-gold"></i>
                        <h3>Quản Lý Phòng</h3>
                        <p>Theo dõi trạng thái phòng trống, cập nhật tình trạng dọn dẹp hoặc báo cáo sự cố kỹ thuật.</p>
                        <a href="/NhanVien/QuanLyPhong" class="btn-gold-action">QUẢN LÝ</a>
                    </div>
                </div>

                <!-- Card 3 -->
                <div class="col-md-4">
                    <div class="uc-card">
                        <i class="fas fa-users-cog fa-2x text-gold"></i>
                        <h3>Khách Hàng</h3>
                        <p>Tiếp nhận yêu cầu nhận phòng (Check-in), trả phòng (Check-out) và xử lý thông tin khách hàng.</p>
                        <a href="/NhanVien/QuanLyKhachHang" class="btn-gold-action">XỬ LÝ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
