@model IEnumerable<WebApplication10.Models.ViewModels.QuanLyKhachHangViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Khách Hàng - Lumina Hotel</title>
    <link rel="stylesheet" href="~/css/lumina-style.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        @await Html.PartialAsync("_SidebarNhanVien")

        <!-- Nội dung chính -->
        <div class="main-content">
            <h2 style="font-family: 'Playfair Display', serif; color: #d4af37; margin-bottom: 30px;">
                Quản Lý Khách Hàng (Check-in/out)
            </h2>

            <!-- Card Chức năng theo SRS (Giữ nguyên code của bạn) -->
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="registration-card">
                        <h4 class="text-dark mb-3"><i class="fas fa-calendar-plus text-gold me-2"></i>Lên lịch nhận phòng</h4>
                        <p class="text-muted small">Danh sách khách hàng đã đặt phòng trực tuyến và đang chờ làm thủ tục nhận phòng.</p>
                        <button class="btn btn-dark w-100" style="background:#d4af37; border:none;">XEM DANH SÁCH CHỜ</button>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="registration-card">
                        <h4 class="text-dark mb-3"><i class="fas fa-file-invoice-dollar text-gold me-2"></i>Tiếp nhận trả phòng</h4>
                        <p class="text-muted small">Xử lý yêu cầu trả phòng, tính toán hóa đơn và xác nhận thanh toán của khách.</p>
                        <button class="btn btn-dark w-100" style="background:#d4af37; border:none;">XỬ LÝ TRẢ PHÒNG</button>
                    </div>
                </div>
            </div>

            <!-- Bảng dữ liệu thực tế từ CSDL -->
            <div class="table-container mt-4">
                <table class="table table-hover mb-0 shadow-sm" style="background: white; border-radius: 10px; overflow: hidden;">
                    <thead style="background: #1a252f; color: #d4af37;">
                        <tr>
                            <th class="p-3">TÊN KHÁCH HÀNG</th>
                            <th class="p-3 text-center">PHÒNG</th>
                            <th class="p-3">NGÀY ĐẾN</th>
                            <th class="p-3">TRẠNG THÁI</th>
                            <th class="p-3 text-center">THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="p-3">
                                        <div class="fw-bold">@item.TenKhachHang</div>
                                        <small class="text-muted">@item.SoDienThoai</small>
                                    </td>
                                    <td class="p-3 text-center">#@item.SoPhong</td>
                                    <td class="p-3">@item.NgayDen</td>
                                    <td class="p-3">
                                        <span class="badge @item.BadgeClass">@item.TrangThaiHienThi</span>
                                    </td>
                                    <td class="p-3 text-center">
                                        <a href="@Url.Action("Details", "Booking", new { id = item.BookingID })" class="btn btn-sm btn-outline-dark">
                                            <i class="fas fa-eye"></i> Xem
                                        </a>

                                        @if (item.ChoPhepDuyet)
                                        {
                                            <form asp-action="DuyetBooking" asp-controller="NhanVien" method="post" style="display:inline;" onsubmit="return confirm('Xác nhận duyệt?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.BookingID" />
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="fas fa-check"></i> Duyệt
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else { /* Thông báo trống */ }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
