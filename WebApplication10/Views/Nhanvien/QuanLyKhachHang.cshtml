@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Khách Hàng - Lumina Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Gọi file CSS dùng chung -->
    @await Html.PartialAsync("_SidebarStyles")
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        @await Html.PartialAsync("_SidebarNhanVien")

        <!-- Nội dung chính -->
        <div class="main-content">
            <h2 style="font-family: 'Playfair Display', serif; color: #d4af37; margin-bottom: 30px;">
                Quản Lý Khách Hàng (Check-in/out)
            </h2>

            <!-- Card Chức năng theo SRS -->
            <div class="row g-4">
                <!-- Nhánh: Lên lịch nhận phòng -->
                <div class="col-md-6">
                    <div class="registration-card">
                        <h4 class="text-dark mb-3"><i class="fas fa-calendar-plus text-gold me-2"></i>Lên lịch nhận phòng</h4>
                        <p class="text-muted small">Danh sách khách hàng đã đặt phòng trực tuyến và đang chờ làm thủ tục nhận phòng.</p>
                        <button class="btn btn-dark w-100" style="background:#d4af37; border:none;">XEM DANH SÁCH CHỜ</button>
                    </div>
                </div>

                <!-- Nhánh: Tiếp nhận trả phòng -->
                <div class="col-md-6">
                    <div class="registration-card">
                        <h4 class="text-dark mb-3"><i class="fas fa-file-invoice-dollar text-gold me-2"></i>Tiếp nhận trả phòng</h4>
                        <p class="text-muted small">Xử lý yêu cầu trả phòng, tính toán hóa đơn và xác nhận thanh toán của khách.</p>
                        <button class="btn btn-dark w-100" style="background:#d4af37; border:none;">XỬ LÝ TRẢ PHÒNG</button>
                    </div>
                </div>
            </div>

            <!-- Bảng mô phỏng dữ liệu (Optional) -->
            <div class="table-container mt-4">
                <table class="table table-hover mb-0">
                    <thead style="background: #1a252f; color: #d4af37;">
                        <tr>
                            <th>TÊN KHÁCH HÀNG</th>
                            <th>PHÒNG</th>
                            <th>NGÀY ĐẾN</th>
                            <th>TRẠNG THÁI</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Nguyễn Hoàng Dũng</td>
                            <td>#101</td>
                            <td>01/04/2026</td>
                            <td><span class="badge bg-warning text-dark">Chờ nhận phòng</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>